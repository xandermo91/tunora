# Tunora API — all secrets. Copy to User Secrets for local dev:
# dotnet user-secrets set "Key" "Value" --project src/Tunora.API

# JWT
JwtOptions__Secret=<random-256-bit-key>
JwtOptions__Issuer=tunora
JwtOptions__Audience=tunora-clients

# Database (local dev uses Windows auth — no secret needed)
# ConnectionStrings__DefaultConnection=Server=localhost\SQLEXPRESS;Database=TunoraDb;Trusted_Connection=True;TrustServerCertificate=True;

# Jamendo
JamendoOptions__ClientId=<your-jamendo-client-id>

# Stripe
StripeOptions__SecretKey=sk_test_...
StripeOptions__WebhookSecret=whsec_...
StripeOptions__StarterPriceId=price_...
StripeOptions__ProfessionalPriceId=price_...
StripeOptions__BusinessPriceId=price_...

# Claude AI Advisor
ClaudeOptions__ApiKey=sk-ant-...

# CORS (production: comma-separated Netlify URLs)
CORS_ORIGINS=https://graceful-crepe-638445.netlify.app,https://vermillion-tartufo-7d748b.netlify.app
